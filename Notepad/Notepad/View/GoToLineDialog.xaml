<Window x:Class="Notepad.View.GoToLineDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Go To Line" Height="130" Width="350"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <StackPanel Margin="15">
        <DockPanel Margin="0,0,0,10">
            <TextBlock Text="Line number:" Width="90" VerticalAlignment="Center" />
            <TextBox x:Name="txtLine" VerticalAlignment="Center" />
        </DockPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Go" Width="75" Margin="0,0,5,0" Click="BtnGo_Click" />
        </StackPanel>
    </StackPanel>
</Window>