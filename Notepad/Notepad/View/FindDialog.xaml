<Window x:Class="Notepad.View.FindDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Find" Height="130" Width="350"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <StackPanel Margin="15">
        <DockPanel Margin="0,0,0,10">
            <TextBlock Text="Find:" Width="90" VerticalAlignment="Center" />
            <TextBox x:Name="txtSearch" VerticalAlignment="Center" />
        </DockPanel>
        <Button Content="Find" Width="75" Click="BtnFind_Click" />
    </StackPanel>
</Window>